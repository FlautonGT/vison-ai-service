# === Vison AI Service - Tier 3 CPU ===

# Server
FACE_AI_HOST=0.0.0.0
FACE_AI_PORT=8000
FACE_AI_WORKERS=2
FACE_AI_DEBUG=false

# Models - Tier 3 (highest accuracy)
MODEL_DIR=/opt/models
ONNX_PROVIDERS=CPUExecutionProvider
SCRFD_MODEL=scrfd_10g_bnkps.onnx
SCRFD_INPUT_SIZE=640
PREFER_INT8_MODELS=true
ARCFACE_MODEL=glintr100.onnx
ARCFACE_EXTRA_MODEL=w600k_r50.onnx
ARCFACE_PRIMARY_WEIGHT=0.65
ARCFACE_EXTRA_WEIGHT=0.35
# Optional higher-accuracy (slower CPU): ARCFACE_MODEL=glintr100.onnx
ARCFACE_FLIP_AUG=true
COMPARE_PARALLEL_EMBEDDING=true
LIVENESS_MODELS=MiniFASNetV2.onnx,MiniFASNetV1SE.onnx
DEEPFAKE_MODELS=deepfake_efficientnet_b0.onnx,community_forensics_vit.onnx
AI_FACE_DETECTOR_MODEL=deepfake_efficientnet_b0.onnx
AI_FACE_EXTRA_DETECTOR_MODEL=ai_vs_deepfake_vs_real.onnx
FACE_PARSING_MODEL=bisenet_face_parsing.onnx
AGE_GENDER_MODEL=genderage.onnx
AGE_GENDER_VIT_MODEL=age_gender_vit.onnx
AGE_GENDER_PRIMARY_WEIGHT=0.5
AGE_GENDER_VIT_WEIGHT=0.5
AGE_GENDER_MALE_THRESHOLD=0.40

# Matching / thresholds
FACE_MATCH_THRESHOLD=0.5
COMPARE_THRESHOLD_DEFAULT=74
# Similarity calibration for AWS-like score scale without changing response schema
SIMILARITY_CALIBRATION_ENABLED=true
SIMILARITY_CALIBRATION_START=75
SIMILARITY_CALIBRATION_GAIN=1.6
SIMILARITY_CALIBRATION_POWER=0.75
SIMILARITY_CALIBRATION_CAP=99.99
SCRFD_SCORE_THRESHOLD=0.5
LIVENESS_THRESHOLD=0.5
DEEPFAKE_THRESHOLD=0.55
DEEPFAKE_FACE_SWAP_STRONG_THRESHOLD=95
AI_FACE_THRESHOLD=68
AI_FACE_LOW_CONF_THRESHOLD=12
AI_FACE_LOW_CONF_FACE_CONF=70
AI_FACE_ALWAYS_CROP_CHECK=true
AI_FACE_HARD_BLOCK_THRESHOLD=85
AI_FACE_VOTE_THRESHOLD=55
AI_FACE_VOTE_MIN_COUNT=2
AI_FACE_ANY_TRIGGER_THRESHOLD=42
AI_FACE_PRIMARY_WEIGHT=0.7
AI_FACE_EXTRA_WEIGHT=0.3
AI_FACE_CALIBRATION_ALPHA=1.0
AI_FACE_CALIBRATION_BETA=0.0
AI_FACE_CONSENSUS_AI_THRESHOLD=80
AI_FACE_CONSENSUS_FACE_SWAP_THRESHOLD=55
AI_FACE_REAL_SUPPRESS_ENABLED=false
AI_FACE_REAL_SUPPRESS_FACE_CONF=72
AI_FACE_REAL_SUPPRESS_AI_MAX=88
AI_FACE_REAL_SUPPRESS_FACE_SWAP_MAX=62
QUALITY_MIN_SCORE=60.0
QUALITY_MIN_SHARPNESS=30
QUALITY_MIN_BRIGHTNESS=30
QUALITY_MAX_BRIGHTNESS=90
QUALITY_POSE_MAX_ABS_DEG=15
QUALITY_MIN_INTER_EYE_PX=60
QUALITY_MAX_ILLUM_ASYMMETRY=30
QUALITY_MIN_CONTRAST=18
FACE_MIN_AREA_RATIO=0.05
FACE_MIN_AREA_RATIO_HARD=0.003
FACE_MIN_PIXELS_HARD=20
ALLOW_SMALL_FACE_AUTOCROP=true
PRE_CROPPED_MIN_DIM=40
PRE_CROPPED_ASPECT_MIN=0.5
PRE_CROPPED_ASPECT_MAX=2.0
RATE_LIMIT_RPS=100

# ONNX runtime tuning for VPS 4 core / 8GB (2 workers)
ONNX_INTRA_OP_THREADS=2
ONNX_INTER_OP_THREADS=1
ONNX_OPT_LEVEL=all
ONNX_EXECUTION_MODE=parallel

# Internal auth with Go backend
AI_SERVICE_SECRET=your-random-secret-here
ALLOWED_IPS=IP_GO_VPS

# No database config in this service
