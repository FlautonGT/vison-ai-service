{
  "task": {
    "name": "face_attributes",
    "type": "multilabel_classification",
    "reporting": "attributes"
  },
  "data": {
    "manifest_root": ".",
    "train_manifest": "data/manifests/face_attributes/train.csv",
    "val_manifest": "data/manifests/face_attributes/val.csv",
    "image_col": "image_path",
    "label_cols": [
      "eyeglasses",
      "sunglasses",
      "mask",
      "hat_cap",
      "major_occlusion"
    ]
  },
  "model": {
    "backbone": "efficientnet_b0",
    "input_size": 224,
    "pretrained": true,
    "dropout": 0.2
  },
  "optimization": {
    "epochs": 15,
    "batch_size": 32,
    "num_workers": 4,
    "lr": 0.0003,
    "weight_decay": 0.0001,
    "mixed_precision": true,
    "grad_clip_norm": 1.0,
    "checkpoint_dir": "runs/face_attributes/checkpoints",
    "resume_from": null
  },
  "evaluation": {
    "report_dir": "runs/face_attributes/reports",
    "slice_columns": [
      "gender",
      "age_group",
      "skin_tone_proxy",
      "region_proxy"
    ]
  },
  "logging": {
    "report_to": "none",
    "project": "vison-ai",
    "run_name": "face-attributes-baseline"
  }
}
