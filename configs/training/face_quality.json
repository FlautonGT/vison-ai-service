{
  "task": {
    "name": "face_quality",
    "type": "regression",
    "reporting": "quality"
  },
  "data": {
    "manifest_root": ".",
    "train_manifest": "data/manifests/face_quality/train.csv",
    "val_manifest": "data/manifests/face_quality/val.csv",
    "image_col": "image_path",
    "label_col": "quality_score"
  },
  "model": {
    "backbone": "efficientnet_b0",
    "input_size": 224,
    "pretrained": true,
    "dropout": 0.2
  },
  "optimization": {
    "epochs": 15,
    "batch_size": 32,
    "num_workers": 4,
    "lr": 0.0003,
    "weight_decay": 0.0001,
    "mixed_precision": true,
    "grad_clip_norm": 1.0,
    "checkpoint_dir": "runs/face_quality/checkpoints",
    "resume_from": null
  },
  "evaluation": {
    "report_dir": "runs/face_quality/reports",
    "accept_threshold": 70.0,
    "slice_columns": [
      "gender",
      "age_group",
      "race_label",
      "region_proxy"
    ]
  },
  "logging": {
    "report_to": "none",
    "project": "vison-ai",
    "run_name": "face-quality-baseline"
  },
  "standards_alignment": {
    "notes": [
      "Quality labels should map to your internal interpretation of ISO/IEC 29794-5 style utility concepts, not to a conformance claim."
    ]
  }
}
